        else:
            text = ""
        if text:
            text = normalize_text(text)
            chunks = chunk_cv_text(text)
            all_chunks.extend(chunks)

    # Build embeddings + vector store
    vectors, embeddings_model = create_embeddings(all_chunks)
    index = build_vector_store(vectors)

